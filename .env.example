# FamiliePlanner – environment variables
# Copy this file to .env and fill in your own values.

# A long random string used to sign session cookies.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string

# Login credentials for the web interface
APP_USERNAME=admin
# Plain text or bcrypt hash. Generate a hash with: python hash_password.py
APP_PASSWORD=familieplanner

# Set to false to disable the login requirement (default: true)
AUTH_REQUIRED=true
